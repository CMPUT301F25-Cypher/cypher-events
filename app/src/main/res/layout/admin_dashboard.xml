<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/tbAdminCommon"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="?attr/colorSurface"
        android:title="Admin Dashboard"
        android:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
        android:titleTextColor="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Stats -->
    <TextView
        android:id="@+id/tvTotalEvents"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Events: 0"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tbAdminCommon"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvTotalProfiles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Profiles: 0"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvTotalEvents"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvTotalImages"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Images: 0"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvTotalProfiles"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- Action Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAdminEvents"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Manage Events"
        style="?attr/materialButtonOutlinedStyle"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/tvTotalImages"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAdminProfiles"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Manage Profiles"
        style="?attr/materialButtonOutlinedStyle"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/btnAdminEvents"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAdminImages"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Manage Images"
        style="?attr/materialButtonOutlinedStyle"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/btnAdminProfiles"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
